}

help_has() {
  cat <<'EOF'
Usage:
  xSHELL has -n NAME [options] [DIR]

Print immediate child directories under DIR according to whether they contain
a file named NAME. By default, only files directly inside each child directory
are checked.

Options:
  -n, --name NAME  File name to check, such as .contact_map.done
  --has           Print directories containing NAME (default)
  -m, --missing   Print directories without NAME
  -b, --both      Print status and directory: HAS<TAB>dir or MISSING<TAB>dir
  -r, --recursive Search recursively inside each child directory
  -D, --depth N   Search up to N levels inside each child directory
  -h, --help      Show this help

Examples:
  xSHELL has -n .contact_map.done .
  xSHELL has -n .contact_map.done -m .
  xSHELL has -n .contact_map.done -b .
  xSHELL has -n .contact_map.done -m -D 2 .
  xSHELL has -n .contact_map.done -m -r /path/to/project
EOF
}

help_ren() {
  cat <<'EOF'
Usage:
  xSHELL ren [options] FILE...

Rename files in batch. By default this command only previews the plan.
Use -y to execute the rename.

Options:
  -x, --strip TEXT     Remove TEXT when it appears at the end of the filename
  -e, --ext OLD:NEW    Change extension OLD to NEW
  -f, --from TEXT      Text to replace in the filename
  -t, --to TEXT        Replacement text for -f
  -y, --yes            Execute the rename
