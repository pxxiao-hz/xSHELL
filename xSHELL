Examples:
  xSHELL ren -x .chr.removedTE.v1.longest.pep.fa *.fa
  xSHELL ren -e fa:fasta *.fa
  xSHELL ren -f _1.fastq -t .RNAseq_1.fastq ALB27_1.fastq
  xSHELL ren -f _1.fastq -t .RNAseq_1.fastq *_1.fastq -y
EOF
}

help_subdir_size() {
  cat <<'EOF'
Usage:
  xSHELL size [options] [DIR]

Show disk usage for immediate child directories.

Options:
  -r, --reverse  Largest first
  -h, --help     Show this help

Examples:
  xSHELL size .
  xSHELL size -r /path/to/project
EOF
}

help_top() {
  cat <<'EOF'
Usage:
  xSHELL top [options]

Show a process snapshot using ps. This is intended for quick non-interactive
checks such as "which jobs is a user running?", "what is this PID?", or
"which processes use the most memory?".

Options:
  -u, --user USER       Show processes owned by USER
  -p, --pid PID[,PID]   Show one or more process IDs
  -g, --grep TEXT       Keep processes whose command contains TEXT
  -s, --sort FIELD      Sort by cpu, mem, rss, time, pid, user, or command
  -n, --limit N         Number of rows to show. Default: 20
  -a, --asc             Sort ascending. Default is descending
  -w, --watch [SEC]     Refresh every SEC seconds. Default: 2
  -h, --help            Show this help

Examples:
  xSHELL top
  xSHELL top -u USER
  xSHELL top -p 12345
  xSHELL top -s mem -n 30
  xSHELL top -s cpu -w 5
  xSHELL top -u USER -g bwa -s rss
EOF
}

help_function() {
  case "${1:-}" in
    ext) help_ext_dirs ;;
    find) help_find_file ;;
    has) help_has ;;
    path) help_path ;;
    ren) help_ren ;;
    size) help_subdir_size ;;
    top) help_top ;;
    "") usage ;;
    *) die "unknown command: $1" ;;
  esac
}

strip_dot() {
  local ext="$1"
  ext="${ext#.}"
  printf '%s\n' "$ext"
}

has_matching_ext() {
  local dir="$1"
  local ext="$2"
  local mode="$3"

  if [ "$mode" = "direct" ]; then
    local f
    for f in "$dir"/*."$ext"; do
      [ -f "$f" ] && return 0
    done
    return 1
  else
    find "$dir" -type f -name "*.$ext" -print -quit 2>/dev/null | grep -q .
  fi
}

cmd_ext_dirs() {
  local dir="."
  local mode="has"
  local ext=""
  local depth="recursive"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --has) mode="has"; shift ;;
      -m|--missing) mode="missing"; shift ;;
      -b|--both) mode="both"; shift ;;
      -e|--ext)
        [ "$#" -ge 2 ] || die "--ext needs a value"
        ext="$(strip_dot "$2")"
        shift 2
        ;;
      -d|--direct) depth="direct"; shift ;;
      -h|-help|--help) help_ext_dirs; return 0 ;;
      --) shift; break ;;
      -*)
        die "unknown option for ext: $1"
        ;;
      *)
        dir="$1"
        shift
        ;;
    esac
  done

  [ -n "$ext" ] || die "ext needs --ext EXT"
  [ -d "$dir" ] || die "not a directory: $dir"

  local child base found any=0
  for child in "$dir"/*; do
    [ -d "$child" ] || continue
    base="${child%/}"
    found=0
    if has_matching_ext "$child" "$ext" "$depth"; then
      found=1
    fi

    case "$mode:$found" in
      has:1)
        printf '%s\n' "$base"
        any=1
        ;;
      missing:0)
        printf '%s\n' "$base"
        any=1
        ;;
      both:1)
        printf 'HAS\t%s\n' "$base"
        any=1
        ;;
      both:0)
        printf 'MISSING\t%s\n' "$base"
        any=1
        ;;
    esac
  done

  [ "$any" -eq 1 ] || return 1
}

has_named_file() {
  local dir="$1"
  local name="$2"
  local mode="$3"

  case "$mode" in
    direct)
      [ -f "$dir/$name" ]
      ;;
    recursive)
      find "$dir" -type f -name "$name" -print -quit 2>/dev/null | grep -q .
      ;;
    *)
      find "$dir" -type f -name "$name" -print 2>/dev/null | awk -v base="$dir/" -v max_depth="$mode" '
        index($0, base) == 1 {
          rel = substr($0, length(base) + 1)
          depth = 1
          for (i = 1; i <= length(rel); i++) {
            if (substr(rel, i, 1) == "/") depth++
          }
          if (depth <= max_depth) {
            found = 1
            exit
          }
        }
        END { exit(found ? 0 : 1) }
      '
      ;;
  esac
}

cmd_has() {
  local dir="."
  local mode="has"
  local name=""
  local depth="direct"

  while [ "$#" -gt 0 ]; do
    case "$1" in
      --has) mode="has"; shift ;;
      -m|--missing) mode="missing"; shift ;;
      -b|--both) mode="both"; shift ;;
      -n|--name)
        [ "$#" -ge 2 ] || die "--name needs a value"
        name="$2"
        shift 2
        ;;
      -r|--recursive) depth="recursive"; shift ;;
      -D|--depth)
        [ "$#" -ge 2 ] || die "--depth needs a positive integer"
        case "$2" in
          ''|*[!0-9]*) die "--depth needs a positive integer" ;;
          0) die "--depth must be greater than 0" ;;
          *) depth="$2" ;;
        esac
        shift 2
        ;;
      -h|-help|--help) help_has; return 0 ;;
      --) shift; break ;;
      -*)
        die "unknown option for has: $1"
        ;;
      *)
        dir="$1"
        shift
        ;;
    esac
  done

  [ -n "$name" ] || die "has needs --name NAME"
  [ -d "$dir" ] || die "not a directory: $dir"

  local child base found any=0
  for child in "$dir"/*; do
    [ -d "$child" ] || continue
    base="${child%/}"
    found=0
    if has_named_file "$child" "$name" "$depth"; then
      found=1
    fi

    case "$mode:$found" in
      has:1)
        printf '%s\n' "$base"
        any=1
        ;;
      missing:0)
        printf '%s\n' "$base"
        any=1
        ;;
      both:1)
        printf 'HAS\t%s\n' "$base"
        any=1
        ;;
      both:0)
        printf 'MISSING\t%s\n' "$base"
        any=1
        ;;
    esac
  done

  [ "$any" -eq 1 ] || return 1
}

stat_size() {
  if stat -f '%z' "$1" >/dev/null 2>&1; then
    stat -f '%z' "$1"
  else
    stat -c '%s' "$1"
  fi
}

stat_mtime() {
  if stat -f '%m' "$1" >/dev/null 2>&1; then
    stat -f '%m' "$1"
  else
    stat -c '%Y' "$1"
  fi
}

format_epoch() {
  local epoch="$1"
  if date -r "$epoch" '+%Y-%m-%d %H:%M:%S' >/dev/null 2>&1; then
    date -r "$epoch" '+%Y-%m-%d %H:%M:%S'
  else
    date -d "@$epoch" '+%Y-%m-%d %H:%M:%S'
  fi
}

human_kb() {
  awk -v kb="$1" 'BEGIN {
    if (kb < 1024) {
      printf "%.0f KB", kb
    } else if (kb < 1048576) {
      printf "%.1f MB", kb / 1024
    } else {
      printf "%.1f GB", kb / 1048576
    }
  }'
}

cmd_find_file() {
  local pattern=""
  local dir="."
  local sort_by="name"
  local reverse=""
  local type="f"
  local contains=""
  local contains_set=0
  local show_count=0

  if [ "$#" -eq 0 ]; then
    help_find_file
    return 0
  fi

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -s|--sort)
        [ "$#" -ge 2 ] || die "--sort needs name, size, or time"
        case "$2" in
          name|size|time|mtime) sort_by="$2" ;;
          *) die "unknown sort field: $2" ;;
        esac
        shift 2
        ;;
      -r|--reverse) reverse="-r"; shift ;;
      -c|--contains)
        [ "$#" -ge 2 ] || die "--contains needs a value"
        contains="$2"
        contains_set=1
        shift 2
        ;;
      --count)
        show_count=1
        shift
        ;;
      --type)
        [ "$#" -ge 2 ] || die "--type needs f, d, or a"
        case "$2" in
          f|d|a) type="$2" ;;
          *) die "unknown type: $2" ;;
        esac
        shift 2
        ;;
      -h|-help|--help) help_find_file; return 0 ;;
      --) shift; break ;;
      -*)
        die "unknown option for find: $1"
        ;;
      *)
        if [ -z "$pattern" ]; then
          pattern="$1"
        else
          dir="$1"
        fi
        shift
        ;;
    esac
  done

  [ -n "$pattern" ] || die "missing PATTERN"
  [ -d "$dir" ] || die "not a directory: $dir"
  if [ "$contains_set" -eq 1 ] && [ "$type" = "d" ]; then
    die "--contains can only be used with files"
  fi

  local find_args=("$dir")
  if [ "$contains_set" -eq 1 ]; then
    find_args+=(-type f)
  elif [ "$type" != "a" ]; then
    find_args+=(-type "$type")
  fi
  find_args+=(-name "$pattern" -print0)

  local tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/xshell-find.XXXXXX")" || die "cannot create temp file"

  local path size mtime display_time count
  while IFS= read -r -d '' path; do
    if [ "$contains_set" -eq 1 ]; then
      if ! grep -I -F -q -- "$contains" "$path" 2>/dev/null; then
        continue
      fi
    fi

    case "$sort_by" in
      size)
        size="$(stat_size "$path" 2>/dev/null || printf '0')"
        if [ "$show_count" -eq 1 ] && [ "$contains_set" -eq 1 ]; then
          count="$(grep -I -F -o -- "$contains" "$path" 2>/dev/null | wc -l | awk '{ print $1 }')"
          printf '%020d\t%s\t%s\n' "$size" "$count" "$path" >> "$tmp"
        else
          printf '%020d\t%s\n' "$size" "$path" >> "$tmp"
        fi
        ;;
      time|mtime)
        mtime="$(stat_mtime "$path" 2>/dev/null || printf '0')"
        if [ "$show_count" -eq 1 ] && [ "$contains_set" -eq 1 ]; then
          count="$(grep -I -F -o -- "$contains" "$path" 2>/dev/null | wc -l | awk '{ print $1 }')"
          printf '%020d\t%s\t%s\n' "$mtime" "$count" "$path" >> "$tmp"
        else
          printf '%020d\t%s\n' "$mtime" "$path" >> "$tmp"
        fi
        ;;
      name)
        if [ "$show_count" -eq 1 ] && [ "$contains_set" -eq 1 ]; then
          count="$(grep -I -F -o -- "$contains" "$path" 2>/dev/null | wc -l | awk '{ print $1 }')"
          printf '%s\t%s\n' "$path" "$count" >> "$tmp"
        else
          printf '%s\n' "$path" >> "$tmp"
        fi
        ;;
    esac
  done < <(find "${find_args[@]}" 2>/dev/null)

  if [ ! -s "$tmp" ]; then
    rm -f "$tmp"
    return 1
  fi

  case "$sort_by" in
    size)
      sort $reverse -n "$tmp" | while IFS=$'\t' read -r size count path; do
        size="$((10#$size))"
        if [ "$show_count" -eq 1 ] && [ "$contains_set" -eq 1 ]; then
          printf '%12d\t%8s\t%s\n' "$size" "$count" "$path"
        else
          path="$count"
          printf '%12d\t%s\n' "$size" "$path"
        fi
      done
      ;;
    time|mtime)
      sort $reverse -n "$tmp" | while IFS=$'\t' read -r mtime count path; do
        mtime="$((10#$mtime))"
        display_time="$(format_epoch "$mtime")"
        if [ "$show_count" -eq 1 ] && [ "$contains_set" -eq 1 ]; then
          printf '%s\t%8s\t%s\n' "$display_time" "$count" "$path"
        else
          path="$count"
          printf '%s\t%s\n' "$display_time" "$path"
        fi
      done
      ;;
    name)
      if [ "$show_count" -eq 1 ] && [ "$contains_set" -eq 1 ]; then
        sort $reverse "$tmp" | while IFS=$'\t' read -r path count; do
          printf '%8s\t%s\n' "$count" "$path"
        done
      else
        sort $reverse "$tmp"
      fi
      ;;
  esac

  rm -f "$tmp"
}

cmd_path() {
  ensure_config
  local action="${1:-list}"
  shift || true

  case "$action" in
    list|ls)
      awk -F '\t' 'BEGIN { OFS="\t" } /^[[:space:]]*#/ || NF < 2 { next } { print $1, $2, $3 }' "$PATH_DB"
      ;;
    get)
      [ "$#" -ge 1 ] || die "path get needs NAME"
      local name="$1"
      local found
      found="$(awk -F '\t' -v key="$name" '$1 == key { print $2; found=1; exit } END { if (!found) exit 1 }' "$PATH_DB")" || die "unknown path name: $name"
      printf '%s\n' "$found"
      ;;
    add)
      [ "$#" -ge 2 ] || die "path add needs NAME and PATH"
      local name="$1"
      local value="$2"
      local desc="${3:-}"
      local tmp
      tmp="$(mktemp "${TMPDIR:-/tmp}/xshell-path.XXXXXX")" || die "cannot create temp file"
      awk -F '\t' -v key="$name" '$1 != key { print }' "$PATH_DB" > "$tmp"
      printf '%s\t%s\t%s\n' "$name" "$value" "$desc" >> "$tmp"
      mv "$tmp" "$PATH_DB" || die "cannot update path database"
      printf 'saved\t%s\t%s\n' "$name" "$value"
      ;;
    remove|rm)
      [ "$#" -ge 1 ] || die "path remove needs NAME"
      local name="$1"
      local tmp
      tmp="$(mktemp "${TMPDIR:-/tmp}/xshell-path.XXXXXX")" || die "cannot create temp file"
      awk -F '\t' -v key="$name" '$1 != key { print }' "$PATH_DB" > "$tmp"
      mv "$tmp" "$PATH_DB" || die "cannot update path database"
      printf 'removed\t%s\n' "$name"
      ;;
    db)
      printf '%s\n' "$PATH_DB"
      ;;
    -h|-help|--help)
      help_path
      ;;
    *)
      local found
      found="$(awk -F '\t' -v key="$action" '$1 == key { print $2; found=1; exit } END { if (!found) exit 1 }' "$PATH_DB")" || die "unknown path name or action: $action"
      printf '%s\n' "$found"
      ;;
  esac
}

replace_all() {
  local text="$1"
  local from="$2"
  local to="$3"

  awk -v text="$text" -v from="$from" -v to="$to" 'BEGIN {
    out = ""
    while ((pos = index(text, from)) > 0) {
      out = out substr(text, 1, pos - 1) to
      text = substr(text, pos + length(from))
    }
    print out text
  }'
}

cmd_ren() {
  local strip_suffix=""
  local ext_pair=""
  local from_text=""
  local to_text=""
  local from_set=0
  local to_set=0
  local execute=0
  local files=()

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -x|--strip)
        [ "$#" -ge 2 ] || die "--strip needs a value"
        strip_suffix="$2"
        shift 2
        ;;
      -e|--ext)
        [ "$#" -ge 2 ] || die "--ext needs OLD:NEW"
        ext_pair="$2"
        shift 2
        ;;
      -f|--from)
        [ "$#" -ge 2 ] || die "--from needs a value"
        from_text="$2"
        from_set=1
        shift 2
        ;;
      -t|--to)
        [ "$#" -ge 2 ] || die "--to needs a value"
        to_text="$2"
        to_set=1
        shift 2
        ;;
      -y|--yes)
        execute=1
        shift
        ;;
      -n|--dry-run)
        execute=0
        shift
        ;;
      -h|-help|--help)
        help_ren
        return 0
        ;;
      --)
        shift
        while [ "$#" -gt 0 ]; do
          files+=("$1")
          shift
        done
        ;;
      -*)
        die "unknown option for ren: $1"
        ;;
      *)
        files+=("$1")
        shift
        ;;
    esac
  done

  [ "${#files[@]}" -gt 0 ] || die "ren needs at least one file"
  if [ -z "$strip_suffix" ] && [ -z "$ext_pair" ] && [ "$from_set" -eq 0 ]; then
    die "ren needs one rename rule: -x, -e, or -f/-t"
  fi
  if [ "$from_set" -eq 1 ] && [ "$to_set" -eq 0 ]; then
    die "--from needs --to"
  fi
  if [ "$from_set" -eq 0 ] && [ "$to_set" -eq 1 ]; then
    die "--to needs --from"
  fi
  if [ "$from_set" -eq 1 ] && [ -z "$from_text" ]; then
    die "--from cannot be empty"
  fi

  local ext_old="" ext_new=""
  if [ -n "$ext_pair" ]; then
    case "$ext_pair" in
      *:*)
        ext_old="${ext_pair%%:*}"
        ext_new="${ext_pair#*:}"
        ext_old="$(strip_dot "$ext_old")"
        ext_new="$(strip_dot "$ext_new")"
        [ -n "$ext_old" ] || die "--ext OLD:NEW needs OLD"
        [ -n "$ext_new" ] || die "--ext OLD:NEW needs NEW"
        ;;
      *)
        die "--ext needs OLD:NEW, for example fa:fasta"
        ;;
    esac
  fi

  local path dir base new target changed=0 planned=0 skipped=0
  for path in "${files[@]}"; do
    if [ ! -e "$path" ]; then
      printf 'SKIP missing\t%s\n' "$path" >&2
      skipped=$((skipped + 1))
      continue
    fi

    dir="${path%/*}"
    base="${path##*/}"
    if [ "$dir" = "$path" ]; then
      dir=""
    fi
    new="$base"

    if [ -n "$strip_suffix" ]; then
      case "$new" in
        *"$strip_suffix") new="${new%"$strip_suffix"}" ;;
      esac
    fi

    if [ -n "$ext_pair" ]; then
      case "$new" in
        *."$ext_old") new="${new%."$ext_old"}.$ext_new" ;;
      esac
    fi

    if [ "$from_set" -eq 1 ]; then
      new="$(replace_all "$new" "$from_text" "$to_text")"
    fi

    if [ "$new" = "$base" ]; then
      printf 'SKIP unchanged\t%s\n' "$path"
      skipped=$((skipped + 1))
      continue
    fi

    if [ -n "$dir" ]; then
      target="$dir/$new"
    else
      target="$new"
    fi

    if [ -e "$target" ]; then
      printf 'SKIP exists\t%s -> %s\n' "$path" "$target" >&2
      skipped=$((skipped + 1))
      continue
    fi

    planned=$((planned + 1))
    if [ "$execute" -eq 1 ]; then
      mv "$path" "$target" || die "failed to rename: $path"
      printf 'RENAMED\t%s -> %s\n' "$path" "$target"
      changed=$((changed + 1))
    else
      printf 'DRY-RUN\t%s -> %s\n' "$path" "$target"
    fi
  done

  if [ "$execute" -eq 0 ]; then
    printf 'Preview only. Add -y to rename. planned=%d skipped=%d\n' "$planned" "$skipped"
  else
    printf 'Done. renamed=%d skipped=%d\n' "$changed" "$skipped"
  fi
}

cmd_subdir_size() {
  local dir="."
  local reverse=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -r|--reverse) reverse="-r"; shift ;;
      -h|-help|--help) help_subdir_size; return 0 ;;
      --) shift; break ;;
      -*)
        die "unknown option for size: $1"
        ;;
      *)
        dir="$1"
        shift
        ;;
    esac
  done

  [ -d "$dir" ] || die "not a directory: $dir"

  local tmp
  tmp="$(mktemp "${TMPDIR:-/tmp}/xshell-du.XXXXXX")" || die "cannot create temp file"
  local child blocks
  for child in "$dir"/*; do
    [ -d "$child" ] || continue
    blocks="$(du -sk "$child" 2>/dev/null | awk '{ print $1 }')"
    printf '%020d\t%s\n' "$blocks" "$child" >> "$tmp"
  done

  if [ ! -s "$tmp" ]; then
    rm -f "$tmp"
    return 1
  fi

  sort $reverse -n "$tmp" | while IFS=$'\t' read -r blocks child; do
    blocks="$((10#$blocks))"
    printf '%10s\t%s\n' "$(human_kb "$blocks")" "$child"
  done

  rm -f "$tmp"
}

top_sort_key() {
  local sort_by="$1"
  awk -F '\t' -v sort_by="$sort_by" '
    function etime_seconds(value, parts, time_parts, n, days, time_text) {
      days = 0
      time_text = value
      if (index(value, "-") > 0) {
        split(value, parts, "-")
        days = parts[1]
        time_text = parts[2]
      }
      n = split(time_text, time_parts, ":")
      if (n == 3) {
        return days * 86400 + time_parts[1] * 3600 + time_parts[2] * 60 + time_parts[3]
      }
      if (n == 2) {
        return days * 86400 + time_parts[1] * 60 + time_parts[2]
      }
      return days * 86400 + time_parts[1]
    }
    {
      if (sort_by == "cpu") {
        key = $4 + 0
      } else if (sort_by == "mem") {
        key = $5 + 0
      } else if (sort_by == "rss") {
        key = $6 + 0
      } else if (sort_by == "time") {
        key = etime_seconds($7)
      } else if (sort_by == "pid") {
        key = $2 + 0
      } else if (sort_by == "user") {
        key = $1
      } else {
        key = $8
      }
      print key "\t" $0
    }
  '
}

top_format_rows() {
  local limit="$1"
  awk -F '\t' -v limit="$limit" '
    BEGIN {
      printf "%8s %-16s %8s %6s %6s %10s %-12s %s\n", "PID", "USER", "PPID", "CPU%", "MEM%", "RSS(KB)", "ELAPSED", "COMMAND"
    }
    NR <= limit {
      printf "%8s %-16s %8s %6s %6s %10s %-12s %s\n", $2, $1, $3, $4, $5, $6, $7, $8
    }
  '
}

run_top_once() {
  local user_filter="$1"
  local pid_filter="$2"
  local grep_filter="$3"
  local sort_by="$4"
  local limit="$5"
  local asc="$6"

  local rows sort_reverse sort_numeric
  rows="$(mktemp "${TMPDIR:-/tmp}/xshell-top.XXXXXX")" || die "cannot create temp file"

  if ! ps -eo user=,pid=,ppid=,pcpu=,pmem=,rss=,etime=,args= 2>/dev/null | awk \
    -v user_filter="$user_filter" \
    -v pid_filter="$pid_filter" \
    -v grep_filter="$grep_filter" '
      BEGIN {
        if (pid_filter != "") {
          split(pid_filter, pid_values, ",")
          for (i in pid_values) {
            wanted_pid[pid_values[i]] = 1
          }
        }
      }
      {
        command = ""
        for (i = 8; i <= NF; i++) {
          command = command (command == "" ? "" : " ") $i
        }
        if (user_filter != "" && $1 != user_filter) next
        if (pid_filter != "" && !($2 in wanted_pid)) next
        if (grep_filter != "" && index(command, grep_filter) == 0) next
        printf "%s\t%s\t%s\t%.1f\t%.1f\t%s\t%s\t%s\n", $1, $2, $3, $4, $5, $6, $7, command
      }
    ' > "$rows"; then
    rm -f "$rows"
    die "cannot read process list with ps"
  fi

  if [ ! -s "$rows" ]; then
    rm -f "$rows"
    return 1
  fi

  sort_reverse="-r"
  [ "$asc" -eq 1 ] && sort_reverse=""

  case "$sort_by" in
    user|command) sort_numeric="" ;;
    *) sort_numeric="-n" ;;
  esac

  top_sort_key "$sort_by" < "$rows" |
    sort -t "$(printf '\t')" $sort_numeric $sort_reverse -k1,1 |
    cut -f2- |
    top_format_rows "$limit"

  rm -f "$rows"
}

cmd_top() {
  local user_filter=""
  local pid_filter=""
  local grep_filter=""
  local sort_by="cpu"
  local limit="20"
  local asc=0
  local watch_seconds=""

  while [ "$#" -gt 0 ]; do
    case "$1" in
      -u|--user)
        [ "$#" -ge 2 ] || die "--user needs a value"
        user_filter="$2"
        shift 2
        ;;
      -p|--pid)
        [ "$#" -ge 2 ] || die "--pid needs a value"
        pid_filter="$2"
        shift 2
        ;;
      -g|--grep|--command)
        [ "$#" -ge 2 ] || die "--grep needs a value"
        grep_filter="$2"
        shift 2
        ;;
      -s|--sort)
        [ "$#" -ge 2 ] || die "--sort needs a field"
        case "$2" in
          cpu|mem|rss|time|pid|user|command) sort_by="$2" ;;
          *) die "unknown top sort field: $2" ;;
        esac
        shift 2
        ;;
      -n|--limit)
        [ "$#" -ge 2 ] || die "--limit needs a number"
        case "$2" in
          ''|*[!0-9]*) die "--limit must be a positive integer" ;;
          *) limit="$2" ;;
        esac
        shift 2
        ;;
      -a|--asc)
        asc=1
        shift
        ;;
      -w|--watch)
        if [ "$#" -ge 2 ] && [ "${2#-}" = "$2" ]; then
          case "$2" in
            ''|*[!0-9]*) die "--watch must be a positive integer number of seconds" ;;
            *) watch_seconds="$2" ;;
          esac
          shift 2
        else
          watch_seconds="2"
          shift
        fi
        ;;
      -h|-help|--help)
        help_top
        return 0
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "unknown option for top: $1"
        ;;
      *)
        grep_filter="$1"
        shift
        ;;
    esac
  done

  if [ "$limit" -lt 1 ]; then
    die "--limit must be greater than 0"
  fi

  if [ -n "$watch_seconds" ]; then
    if [ "$watch_seconds" -lt 1 ]; then
      die "--watch must be greater than 0"
    fi
    while :; do
      clear
      date '+%Y-%m-%d %H:%M:%S'
      run_top_once "$user_filter" "$pid_filter" "$grep_filter" "$sort_by" "$limit" "$asc" || true
      sleep "$watch_seconds"
    done
  else
    run_top_once "$user_filter" "$pid_filter" "$grep_filter" "$sort_by" "$limit" "$asc"
  fi
}

dispatch() {
  local cmd="${1:--h}"
  shift || true

  case "$cmd" in
    list)
      list_functions
      ;;
    version|-v|--version)
      print_version
      ;;
    -h|-help|--help)
      if [ "$#" -gt 0 ]; then
        help_function "$1"
      else
        usage
      fi
      ;;
    ext)
      cmd_ext_dirs "$@"
      ;;
    find)
      cmd_find_file "$@"
      ;;
    has)
      cmd_has "$@"
      ;;
    path)
      cmd_path "$@"
      ;;
    ren)
      cmd_ren "$@"
      ;;
    size)
      cmd_subdir_size "$@"
      ;;
    top)
      cmd_top "$@"
      ;;
    *)
      die "unknown command: $cmd. Run: $PROG -h"
      ;;
  esac
}

dispatch "$@"
