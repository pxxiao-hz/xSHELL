#!/usr/bin/env bash

set -u

PROG="$(basename "$0")"
VERSION="0.4.0"
CONFIG_DIR="${XSHELL_CONFIG_DIR:-$HOME/.config/xSHELL}"
PATH_DB="$CONFIG_DIR/paths.tsv"

die() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

ensure_config() {
  mkdir -p "$CONFIG_DIR" || die "cannot create config dir: $CONFIG_DIR"
  if [ ! -f "$PATH_DB" ]; then
    {
      printf '# name\tpath\tdescription\n'
      printf 'ref-genome\t/data/reference/genome.fa\treference genome fasta\n'
    } > "$PATH_DB" || die "cannot write path database: $PATH_DB"
  fi
}

usage() {
  cat <<'EOF'
xSHELL - small shell helper collection
Version: 0.4.0

Usage:
  xSHELL <name> [args]
  xSHELL list
  xSHELL -h
  xSHELL version

Commands:
  ext           Print child directories that have or miss files by extension
  find          Find files/directories and sort by size, time, or name
  has           Print child directories that have or miss a named file
  path          Store and print frequently used paths
  ren           Rename files in batch with preview
  size          Show child directory sizes
  top           Show process snapshots by user, PID, CPU, or memory
  version       Print xSHELL version

Examples:
  xSHELL ext -e tsv .
  xSHELL ext -e fasta -m .
  xSHELL find '*.fa*' -s size -r .
  xSHELL has -n .contact_map.done -m .
  xSHELL ren -e fa:fasta *.fa
  xSHELL path ref-genome
  xSHELL top -u USER -s mem -n 20
  xSHELL path add ref /data/reference/genome.fa 'reference genome'
EOF
}

list_functions() {
  printf '%s\n' ext find has path ren size top version
}

print_version() {
  printf 'xSHELL %s\n' "$VERSION"
}

help_ext_dirs() {
  cat <<'EOF'
Usage:
  xSHELL ext -e EXT [options] [DIR]

Print immediate child directories under DIR according to whether they contain
files ending with EXT. By default the check is recursive inside each child
directory.

Options:
  -e, --ext EXT  File extension to check, such as tsv, fa, fasta, or vcf
  --has          Print directories containing matching files (default)
  -m, --missing  Print directories without matching files
  -b, --both     Print status and directory: HAS<TAB>dir or MISSING<TAB>dir
  -d, --direct   Only check files directly under each child directory
  -h, --help     Show this help

Examples:
  xSHELL ext -e tsv .
  xSHELL ext -e fasta -m /path/to/project
  xSHELL ext -e vcf -b -d .
EOF
}

help_find_file() {
  cat <<'EOF'
Usage:
  xSHELL find PATTERN [options] [DIR]

Find paths matching PATTERN recursively under DIR. PATTERN uses shell glob
syntax such as '*.tsv', '*genome*', or 'ref*.fasta'.

Options:
  -s, --sort name    Sort by path/name (default)
  -s, --sort size    Sort by file size
  -s, --sort time    Sort by modified time
  -r, --reverse      Reverse sort order
  -c, --contains TXT Keep files containing TXT
  --count            With -c, print match count before each file
  --type f|d|a       File, directory, or all path types. Default: f
  -h, --help         Show this help

Examples:
  xSHELL find '*.tsv' -s size -r .
  xSHELL find '*genome*' -s time /path/to/project
  xSHELL find '*.fa' -c '*'
  xSHELL find '*.fa' -c '>' --count
  xSHELL find 'results' --type d .
EOF
}

help_path() {
  cat <<'EOF'
Usage:
  xSHELL path <action> [args]

Actions:
  list, ls                     List saved paths
  get NAME                     Print one saved path
  NAME                         Print one saved path
  add NAME PATH [DESCRIPTION]  Add or replace a saved path
  remove, rm NAME              Remove a saved path
  db                           Print path database location

Examples:
  xSHELL path ref-genome
  xSHELL path add ref /data/reference/genome.fa 'reference genome'
  xSHELL path ls

Shell shortcut example:
  alias refgenome='xSHELL path ref-genome'
